	<bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
		<property name="driverClassName" value="#{systemProperties['database.driverClassName']}"/>
		<property name="url"  value="#{systemProperties['database.url']}" />
		<property name="username"  value="#{systemProperties['database.username']}"/>
		<property name="password"  value="#{systemProperties['database.password']}"/>
	</bean>

    

    
    <bean id="clientConfiguration" class="com.amazonaws.ClientConfiguration">
		<property name="maxConnections" value="10" />
	</bean>
	
	<bean id="amazonSQS" class="com.amazonaws.services.sqs.AmazonSQSClient">
		<constructor-arg name="clientConfiguration" ref="clientConfiguration"/>
	</bean>	
	<bean id="sesClient" class="com.amazonaws.services.simpleemail.AmazonSimpleEmailServiceClient">		
	</bean>	  

	<bean id="fIFOQueueServiceImpl" class="org.ets.ibt2.cloud.common.service.impl.FIFOQueueServiceImpl">
	</bean>		
	
	<bean id="simpleMailServiceImpl" class="org.ets.ibt2.cloud.services.notification.mail.SimpleMailServiceImpl"/>		
	
