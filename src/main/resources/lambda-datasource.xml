	</bean>		
	<bean id="tableNameOverride" class="org.springframework.beans.factory.config.MethodInvokingFactoryBean">
   		<property name="arguments" value="#{propertyRef['env']=='developers'?'ets-ibt2-'+ propertyRef['env'] + '-' + propertyRef['developer'] + '-':'ets-ibt2-'+ propertyRef['env'] + '-'}"/> 
   		<property name="arguments" value="ets-ibtdel-developers-panderson-"/>
        <property name="staticMethod" value="com.amazonaws.services.dynamodbv2.datamodeling.DynamoDBMapperConfig.TableNameOverride.withTableNamePrefix"/>
    </bean>  
    <bean id="etsDynamoDBMapperConfig" class="com.amazonaws.services.dynamodbv2.datamodeling.DynamoDBMapperConfig">
        <constructor-arg index="0" ref="tableNameOverride" />
    </bean>
	
	<bean id="etsDynamoDBClient" class="com.amazonaws.services.dynamodbv2.AmazonDynamoDBClient">
		<property name="endpoint" value="${dynamodb_endpoint_url}" />
	</bean>

	<bean id="etsDynamoDBMapper" class="com.amazonaws.services.dynamodbv2.datamodeling.DynamoDBMapper">
		<constructor-arg ref="etsDynamoDBClient" />
		<constructor-arg ref="etsDynamoDBMapperConfig" />
		<constructor-arg ref="defaultAWSCredentialsProviderChain" />
	</bean>

	<bean id="defaultAWSCredentialsProviderChain" class="com.amazonaws.auth.DefaultAWSCredentialsProviderChain">
	</bean>
	
