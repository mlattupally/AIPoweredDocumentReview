<configuration>

    <jmxConfigurator/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <Pattern>%-75(%d{yyyy HH:mm:ss.SSS} |-%-5level in %logger{35}[%thread]) -- %marker %msg%n</Pattern>
        </encoder>
    </appender>

       
    <logger name="org.ets.ibt" level="INFO">
    </logger>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
       
    </root>

</configuration>
