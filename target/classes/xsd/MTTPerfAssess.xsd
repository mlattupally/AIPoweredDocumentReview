<?xml version="1.0" encoding="utf-8" ?> 
<xs:schema 
        targetNamespace="http://crds.ets.org/crdsnet/schema/MTTPerfAssess"
        elementFormDefault="qualified"
        xmlns="http://crds.ets.org/crdsnet/schema/MTTPerfAssess"
        xmlns:xs="http://www.w3.org/2001/XMLSchema"
        version="01.00">
        
	<xs:annotation>
		<xs:documentation>Texas MTT Performance Assessments</xs:documentation>
	</xs:annotation>        
	
	<xs:element name="mttPerformanceAssessment">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="AppointmentNumber">
					<xs:simpleType>
						<xs:restriction base="xs:normalizedString">
							<xs:length value="16" />
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="RegistrationSystemId">
					<xs:simpleType>
						<xs:restriction base="xs:normalizedString">
							<xs:maxLength value="6" />
							<xs:minLength value="1" />
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="ScoreReportingFlag">
					<xs:simpleType>
						<xs:restriction base="xs:token">
							<xs:enumeration value="No" />
							<xs:enumeration value="Yes" />
							<xs:enumeration value="NotReached" />
						</xs:restriction>
					</xs:simpleType>
				</xs:element>
				<xs:element name="DateOfBirth" type="xs:date"/>
				<xs:element name="PerformanceItems" type="PerformanceItems_t" />
				<xs:element name="PerformanceLog" type="xs:string" minOccurs="0"  nillable="true"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	
	<xs:complexType name="PerformanceItems_t">
		<xs:choice>
			<xs:element name="PerformanceItem" type="PerformanceItem_t" maxOccurs="unbounded"/>
		</xs:choice>
	</xs:complexType>
	
	<xs:complexType name="PerformanceItem_t">
		<xs:sequence>		
			<xs:element name="ItemID">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="23" />
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="FileType">
				<xs:simpleType>
					<xs:restriction base="xs:token">
						<xs:maxLength value="3"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="FileLocation" type="xs:anyURI" />
			<xs:element name="FileSize" type="xs:nonNegativeInteger" />							
		</xs:sequence>	
	</xs:complexType>
	
</xs:schema>
